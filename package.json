{
  "name": "lemans-box",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "vue": "^3.5.39",
    "vue-router": "^4.4.5",
    "gsap": "^3.12.5",
    "lenis": "^1.1.18",
    "lucide-vue-next": "^0.462.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "@vercel/analytics": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "eslint": "^9.15.0",
    "@eslint/js": "^9.15.0",
    "typescript-eslint": "^8.15.0",
    "eslint-plugin-vue": "^9.31.0",
    "vue-eslint-parser": "^9.4.3",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "eslint-config-prettier": "^9.1.0",
    "simple-git-hooks": "^2.11.1",
    "lint-staged": "^15.2.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
